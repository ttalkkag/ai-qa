{
  "respectGitignore": true,
  "cleanupPeriodDays": 28,
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "deny": [
      "Read(.env)",
      "Read(.env.prod*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/*.p12)",
      "Read(**/*.pfx)",
      "Read(**/*.crt)",
      "Read(**/*.cer)",
      "Read(**/*.jks)",
      "Read(**/*.keystore)",
      "Read(**/*.tfvars)",
      "Read(**/id_rsa*)",
      "Read(**/id_ed25519*)",
      "Read(**/.ssh/*)",
      "Read(**/.aws/*)",
      "Read(**/credentials.json)",
      "Read(**/.netrc)",
      "Read(**/.npmrc)",
      "Read(**/.git-credentials)",
      "Read(**/.kube/config)",
      "Read(**/.gnupg/**)",
      "Edit(../**)",
      "Write(../**)"
    ],
    "defaultMode": "bypassPermissions"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "^Bash$",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.hooks/block_git_origin_push.sh\"",
            "timeout": 10,
            "statusMessage": "Checking git push origin"
          },
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.hooks/block_global_system_commands.sh\"",
            "timeout": 10,
            "statusMessage": "Checking global/system command"
          },
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.hooks/block_global_package_install.sh\"",
            "timeout": 10,
            "statusMessage": "Checking global package install"
          },
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.hooks/block_pipe_to_shell.sh\"",
            "timeout": 10,
            "statusMessage": "Checking pipe-to-shell"
          }
        ]
      },
      {
        "matcher": "^(Edit|MultiEdit|Write|apply_patch)$",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.hooks/block_dependency_folder_edits.sh\"",
            "timeout": 10,
            "statusMessage": "Checking dependency folder edit"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "agent-sdk-dev@claude-plugins-official": false,
    "clangd-lsp@claude-plugins-official": false,
    "claude-code-setup@claude-plugins-official": false,
    "claude-md-management@claude-plugins-official": false,
    "code-review@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "codex@openai-codex": true,
    "commit-commands@claude-plugins-official": false,
    "context7@claude-plugins-official": true,
    "csharp-lsp@claude-plugins-official": false,
    "explanatory-output-style@claude-plugins-official": false,
    "feature-dev@claude-plugins-official": false,
    "firecrawl@claude-plugins-official": false,
    "firebase@claude-plugins-official": false,
    "frontend-design@claude-plugins-official": false,
    "github@claude-plugins-official": false,
    "gitlab@claude-plugins-official": false,
    "gopls-lsp@claude-plugins-official": false,
    "hookify@claude-plugins-official": true,
    "kotlin-lsp@claude-plugins-official": false,
    "laravel-boost@claude-plugins-official": false,
    "learning-output-style@claude-plugins-official": false,
    "linear@claude-plugins-official": false,
    "php-lsp@claude-plugins-official": false,
    "playground@claude-plugins-official": false,
    "playwright@claude-plugins-official": true,
    "plugin-dev@claude-plugins-official": false,
    "pr-review-toolkit@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": false,
    "ralph-loop@claude-plugins-official": true,
    "remember@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": false,
    "security-guidance@claude-plugins-official": true,
    "serena@claude-plugins-official": false,
    "skill-creator@claude-plugins-official": false,
    "supabase@claude-plugins-official": false,
    "superpowers@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": false,
    "vercel@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    }
  },
  "language": "korean",
  "spinnerTipsEnabled": false,
  "alwaysThinkingEnabled": true,
  "effortLevel": "xhigh",
  "companyAnnouncements": [
    "\nWelcome to {base}!\nRun 'make init' on first launch."
  ],
  "autoUpdatesChannel": "latest",
  "skipDangerousModePermissionPrompt": true
}
